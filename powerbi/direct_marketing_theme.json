{
  "name": "Direct Marketing Portfolio Theme",
  "dataColors": [
    "#0E7490",
    "#134E4A",
    "#B45309",
    "#60A5FA",
    "#94A3B8",
    "#D97706",
    "#64748B",
    "#1F2933"
  ],
  "background": "#F5F1EA",
  "foreground": "#1F2933",
  "tableAccent": "#0E7490",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontFace": "Segoe UI Semibold",
            "fontSize": 12,
            "color": {
              "solid": {
                "color": "#1F2933"
              }
            }
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#164E63"
              }
            },
            "fontSize": 22
          }
        ],
        "categoryLabels": [
          {
            "color": {
              "solid": {
                "color": "#64748B"
              }
            },
            "fontSize": 10
          }
        ]
      }
    }
  }
}
